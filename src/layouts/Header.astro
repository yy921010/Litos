---
import { HEADER_LINKS } from '~/config'
import { SITE } from '~/config'
import { SOCIAL_LINKS } from '~/config'
import ThemeToggle from '~/components/theme/ThemeToggle'
import SearchSwitch from '~/components/base/SearchSwitch.astro'

const githubLink = SOCIAL_LINKS.find((item) => item.name.toLowerCase() === 'github')?.url
---

<header class="border-b border-border/70">
  <div class="mx-auto global-layout-width flex flex-wrap items-center justify-between gap-y-3 px-6 py-4 sm:px-8">
    <div class="flex grow items-center gap-7 font-sans text-[0.95rem] font-semibold uppercase tracking-[0.03em]">
      <a href="/" class="pointer-events-auto select-none text-foreground tracking-[0.04em]" transition:persist>
        {SITE.title}
      </a>
      <nav class="ml-auto flex flex-wrap items-center justify-end gap-4 text-muted-foreground">
        {
          HEADER_LINKS.map((link) => (
            <a
              href={link.url}
              class:list={[
                'hover:text-foreground transition-colors',
                Astro.url.pathname.startsWith(link.url) && 'text-foreground',
              ]}
            >
              {link.name}
            </a>
          ))
        }
        {githubLink && (
          <a href={githubLink} target="_blank" rel="noreferrer" class="hover:text-foreground transition-colors">
            GitHub
          </a>
        )}
      </nav>
    </div>
    <div class="flex items-center gap-3 text-muted-foreground uppercase tracking-[0.04em] text-sm font-semibold" transition:persist="header-theme-toggle">
      <SearchSwitch />
      <a
        href="/atom.xml"
        target="_blank"
        class="inline-flex items-center hover:text-foreground transition-colors"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        RSS
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
