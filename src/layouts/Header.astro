---
import { HEADER_LINKS } from '~/config'
import { SITE } from '~/config'
import { SOCIAL_LINKS } from '~/config'
import ThemeToggle from '~/components/theme/ThemeToggle'
import SearchSwitch from '~/components/base/SearchSwitch.astro'

const githubLink = SOCIAL_LINKS.find((item) => item.name.toLowerCase() === 'github')?.url

const navIconMap: Record<string, string> = {
  Posts: 'icon-[ri--article-line]',
  Projects: 'icon-[ri--lightbulb-line]',
  Photos: 'icon-[ri--camera-3-line]',
  Friends: 'icon-[ri--heart-line]',
}
---

<header class="border-b border-border/60 bg-background/55 backdrop-blur-md supports-[backdrop-filter]:bg-background/45">
  <div class="w-full flex min-h-14 flex-wrap items-center justify-between gap-y-3 px-4 py-3.5 sm:min-h-16 sm:px-8 sm:py-4">
    <div class="flex grow items-center gap-4 sm:gap-7 font-sans text-[0.95rem] font-semibold uppercase tracking-[0.03em]">
      <a href="/" class="pointer-events-auto select-none text-foreground tracking-[0.04em]" transition:persist>
        {SITE.title}
      </a>
      <nav class="ml-auto flex flex-wrap items-center justify-end gap-2 sm:gap-4 text-muted-foreground">
        {
          HEADER_LINKS.map((link) => (
            <a
              href={link.url}
              class:list={[
                'inline-flex h-10 w-10 items-center justify-center rounded-md hover:text-foreground hover:bg-muted/40 transition-colors sm:h-auto sm:w-auto sm:bg-transparent',
                Astro.url.pathname.startsWith(link.url) && 'text-foreground',
              ]}
              title={link.name}
              aria-label={link.name}
            >
              <span class:list={['size-5 sm:hidden', navIconMap[link.name] || 'icon-[ri--links-line]']}></span>
              <span class="hidden sm:inline">{link.name}</span>
            </a>
          ))
        }
        {githubLink && (
          <a
            href={githubLink}
            target="_blank"
            rel="noreferrer"
            class="inline-flex h-10 w-10 items-center justify-center rounded-md hover:text-foreground hover:bg-muted/40 transition-colors sm:h-auto sm:w-auto sm:bg-transparent"
            title="GitHub"
            aria-label="GitHub"
          >
            <span class="icon-[ri--github-line] size-5 sm:hidden"></span>
            <span class="hidden sm:inline">GitHub</span>
          </a>
        )}
      </nav>
    </div>
    <div class="flex items-center gap-2 sm:gap-3 text-muted-foreground uppercase tracking-[0.04em] text-sm font-semibold" transition:persist="header-theme-toggle">
      <SearchSwitch />
      <a
        href="/atom.xml"
        target="_blank"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md hover:text-foreground hover:bg-muted/40 transition-colors sm:h-auto sm:w-auto sm:bg-transparent"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <span class="icon-[ri--rss-line] size-5 sm:hidden"></span>
        <span class="hidden sm:inline">RSS</span>
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
