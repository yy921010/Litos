---
import { FOOTER_LINKS, SITE } from '~/config'
import ThemeToggle from '~/components/theme/ThemeToggle'

const START_YEAR = 2025
const currentYear = new Date().getFullYear()
const yearDisplay = currentYear > START_YEAR ? `${START_YEAR} - ${currentYear}` : `${START_YEAR}`
---

<footer class="border-t border-border/70">
  <div class="global-layout-width mx-auto px-6 py-4 sm:px-8 text-sm font-mono text-muted-foreground">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      <span>© {yearDisplay}</span>
      <span>·</span>
      <span>{SITE.author}</span>
      <span>·</span>
      {FOOTER_LINKS.map((link, index) => (
        <>
          {index > 0 && <span>·</span>}
          <a href={link.url} class="hover:text-foreground hover:underline decoration-dashed underline-offset-4">
            {link.name}
          </a>
        </>
      ))}
      <span class="ml-auto inline-flex items-center" transition:persist="footer-theme-toggle">
        <ThemeToggle client:load />
      </span>
    </div>
  </div>
</footer>
