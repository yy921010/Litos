---
import { POSTS_CONFIG, SITE, SOCIAL_LINKS } from '~/config.ts'
import Layout from '~/layouts/Layout.astro'
import SocialLink from '~/components/base/SocialLink.astro'
import { getNumPosts, getPinnedPosts } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import { PhotosList } from '~/lib/photos'
import HomePhotoPreviewGrid from '~/components/photos/HomePhotoPreviewGrid'
import BlurText from '~/components/reactbits/BlurText'
import ArchiveGroupsList from '~/components/home/ArchiveGroupsList'

const { size } = POSTS_CONFIG.homePageConfig

let showPosts = []
const pinnedPosts = await getPinnedPosts()
const hasPinnedPosts = pinnedPosts.length > 0
if (hasPinnedPosts) {
  showPosts = pinnedPosts
} else {
  showPosts = await getNumPosts(size)
}

const sortedPosts = showPosts.slice().sort((a, b) => {
  const dateA = a.data.updatedDate ?? a.data.pubDate
  const dateB = b.data.updatedDate ?? b.data.pubDate
  return dateB.getTime() - dateA.getTime()
})

const archiveMap = new Map<number, typeof sortedPosts>()
for (const post of sortedPosts) {
  const date = post.data.updatedDate ?? post.data.pubDate
  const year = date.getFullYear()
  const group = archiveMap.get(year)
  if (group) {
    group.push(post)
  } else {
    archiveMap.set(year, [post])
  }
}
const archiveGroups = Array.from(archiveMap.entries()).sort((a, b) => b[0] - a[0])
const archiveGroupsForUI = archiveGroups.map(([year, posts]) => ({
  year,
  posts: posts.map((post) => {
    const date = post.data.updatedDate ?? post.data.pubDate
    return {
      date: formatDate(date, 'iso'),
      title: post.data.title,
      url: `/posts/${post.id}`,
    }
  }),
}))

const photoPreviewList = PhotosList.flatMap((album) =>
  album.photos.map((photo) => ({
    ...photo,
    date: album.date,
    albumTitle: album.title,
  }))
)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 10)
const homeSvgBackgrounds = Object.values(
  import.meta.glob<string>('/src/assets/svg/*.svg', { eager: true, import: 'default', query: '?url' })
)
const initialHomeSvgBackground = homeSvgBackgrounds[0] ?? ''
---

<Layout title="Home" description={SITE.description}>
  <div class="relative z-[1] px-6 py-8 sm:px-8 sm:py-10 font-mono text-[15px] leading-7">
    <div class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 overflow-hidden">
      <div
        id="home-random-svg-bg"
        class="absolute inset-0 bg-right bg-contain bg-no-repeat opacity-58"
        data-svg-list={JSON.stringify(homeSvgBackgrounds)}
        style={`background-image: url('${initialHomeSvgBackground}');`}
      ></div>
      <div class="absolute inset-0 dark:hidden bg-[linear-gradient(145deg,rgba(255,255,255,0.56)_0%,rgba(255,255,255,0.9)_48%,rgba(255,255,255,0.82)_100%)]"></div>
      <div class="absolute inset-0 hidden dark:block bg-[linear-gradient(145deg,rgba(2,6,23,0.64)_0%,rgba(2,6,23,0.9)_50%,rgba(2,6,23,0.86)_100%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_72%_46%_at_68%_0%,rgba(80,80,180,0.12),transparent_72%)] dark:bg-[radial-gradient(ellipse_72%_46%_at_68%_0%,rgba(120,120,255,0.16),transparent_72%)]"></div>
      <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
    </div>

    <section class="grid min-h-[65svh] items-center gap-8 lg:grid-cols-[1fr_20rem]">
      <div class="space-y-6">
        <BlurText
          text={SITE.title}
          animateBy="letters"
          direction="top"
          delay={80}
          className="font-sans text-[clamp(2.35rem,6vw,5.2rem)] leading-[1.02] tracking-[-0.045em] font-semibold text-foreground uppercase"
          client:load
        />

        <div class="fade-up animation-delay-150 space-y-3">
          <p class="max-w-[42ch] text-base sm:text-lg font-sans font-normal tracking-tight text-foreground/90">
            代码、写作与影像并行。这里记录我做过的项目、长期思考和日常观察。
          </p>
          <div class="flex flex-wrap items-center gap-3 text-xs sm:text-sm text-muted-foreground">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border/70 bg-background/55 px-3 py-1">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-subtle-pulse"></span>
              Available for work
            </span>
            <span class="inline-flex items-center rounded-full border border-border/70 bg-background/55 px-3 py-1">Nanjing, China</span>
            <span class="inline-flex items-center rounded-full border border-border/70 bg-background/55 px-3 py-1">UTC+8</span>
          </div>
        </div>

        <div class="fade-up animation-delay-300 flex flex-wrap gap-3 pt-1">
          {
            SOCIAL_LINKS.map((item) => (
              <SocialLink href={item.url} icon={item.icon} aria-label={`Link of ${item.name}`} count={item.count} label="followers" />
            ))
          }
        </div>
      </div>

      <aside class="fade-up animation-delay-400 rounded-2xl border border-border/70 bg-background/55 p-5 backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.16em] text-muted-foreground">Now</p>
        <p class="mt-3 text-sm text-foreground/90">Building practical web products with strong writing and visual storytelling.</p>
        <div class="mt-5 space-y-3 text-sm">
          <a href="/posts" class="group flex items-center justify-between rounded-lg border border-border/60 bg-background/65 px-3 py-2 hover:border-foreground/30 transition-colors">
            <span>Writing</span>
            <span class="text-muted-foreground group-hover:translate-x-0.5 transition-transform">→</span>
          </a>
          <a href="/projects" class="group flex items-center justify-between rounded-lg border border-border/60 bg-background/65 px-3 py-2 hover:border-foreground/30 transition-colors">
            <span>Projects</span>
            <span class="text-muted-foreground group-hover:translate-x-0.5 transition-transform">→</span>
          </a>
          <a href="/photos" class="group flex items-center justify-between rounded-lg border border-border/60 bg-background/65 px-3 py-2 hover:border-foreground/30 transition-colors">
            <span>Photography</span>
            <span class="text-muted-foreground group-hover:translate-x-0.5 transition-transform">→</span>
          </a>
        </div>
      </aside>
    </section>

    <div class="grid gap-4 pb-2 sm:grid-cols-3">
      <a href="/posts" class="group rounded-xl border border-border/70 bg-background/50 p-4 transition-colors hover:border-foreground/25">
        <p class="text-xs uppercase tracking-[0.12em] text-muted-foreground">Archive</p>
        <p class="mt-2 font-sans text-xl font-semibold tracking-tight text-foreground">{sortedPosts.length}</p>
        <p class="mt-1 text-xs text-muted-foreground">Selected writings</p>
      </a>
      <a href="/photos" class="group rounded-xl border border-border/70 bg-background/50 p-4 transition-colors hover:border-foreground/25">
        <p class="text-xs uppercase tracking-[0.12em] text-muted-foreground">Photo</p>
        <p class="mt-2 font-sans text-xl font-semibold tracking-tight text-foreground">{photoPreviewList.length}</p>
        <p class="mt-1 text-xs text-muted-foreground">Recent captures</p>
      </a>
      <a href="/projects" class="group rounded-xl border border-border/70 bg-background/50 p-4 transition-colors hover:border-foreground/25">
        <p class="text-xs uppercase tracking-[0.12em] text-muted-foreground">Build</p>
        <p class="mt-2 font-sans text-xl font-semibold tracking-tight text-foreground">Open</p>
        <p class="mt-1 text-xs text-muted-foreground">Things I am making</p>
      </a>
    </div>

    <div class="flex items-center gap-4 py-8">
      <div class="h-px flex-1 bg-border/40"></div>
      <div class="h-1.5 w-1.5 rounded-full bg-border/60"></div>
      <div class="h-px flex-1 bg-border/40"></div>
    </div>

    <section class="py-2">
      <div class="mb-6 flex items-baseline justify-between gap-4">
        <div>
          <div class="mb-1 flex items-center gap-2">
            <span class="text-xs font-mono uppercase tracking-wider text-muted-foreground">Writing</span>
            <span class="h-px w-6 bg-border/50"></span>
          </div>
          <h2 class="text-2xl font-sans font-medium tracking-tight text-foreground">{hasPinnedPosts ? 'Pinned' : 'Recent'}</h2>
        </div>
        <a href="/posts" class="group flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">
          <span>View all</span>
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <ArchiveGroupsList groups={archiveGroupsForUI} client:visible />
    </section>

    <div class="flex items-center gap-4 py-8">
      <div class="h-px flex-1 bg-border/40"></div>
      <div class="h-1.5 w-1.5 rounded-full bg-border/60"></div>
      <div class="h-px flex-1 bg-border/40"></div>
    </div>

    <section class="py-2">
      <div class="mb-6 flex items-baseline justify-between gap-4">
        <div>
          <div class="mb-1 flex items-center gap-2">
            <span class="text-xs font-mono uppercase tracking-wider text-muted-foreground">Photography</span>
            <span class="h-px w-6 bg-border/50"></span>
          </div>
          <h2 class="text-2xl font-sans font-medium tracking-tight text-foreground">Latest Shots</h2>
        </div>
        <a href="/photos" class="group flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">
          <span>View gallery</span>
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <HomePhotoPreviewGrid photos={photoPreviewList} title="Latest Shots" description="Recent captures from everyday life." client:load />
    </section>
  </div>
</Layout>

<script is:inline>
  const homeBgEl = document.getElementById('home-random-svg-bg')
  const homeSvgListRaw = homeBgEl?.getAttribute('data-svg-list') ?? '[]'
  let homeSvgList = []
  try {
    const parsedSvgList = JSON.parse(homeSvgListRaw)
    if (Array.isArray(parsedSvgList)) {
      homeSvgList = parsedSvgList.filter((item) => typeof item === 'string')
    }
  } catch {
    homeSvgList = []
  }

  if (homeBgEl && homeSvgList.length > 0) {
    let randomIndex = Math.floor(Math.random() * homeSvgList.length)
    try {
      const cacheKey = 'home-random-svg-index'
      const previousIndex = Number(window.sessionStorage.getItem(cacheKey))
      if (Number.isInteger(previousIndex) && homeSvgList.length > 1 && previousIndex === randomIndex) {
        randomIndex = (randomIndex + 1) % homeSvgList.length
      }
      window.sessionStorage.setItem(cacheKey, String(randomIndex))
    } catch {
      // Ignore sessionStorage errors in restricted contexts.
    }
    homeBgEl.style.backgroundImage = `url("${homeSvgList[randomIndex]}")`
  }
</script>
