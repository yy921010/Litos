---
import { POSTS_CONFIG, SITE, SOCIAL_LINKS } from '~/config.ts'
import Layout from '~/layouts/Layout.astro'
import SocialLink from '~/components/base/SocialLink.astro'
import { getNumPosts, getPinnedPosts } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import { PhotosList } from '~/lib/photos'
import HomePhotoPreviewGrid from '~/components/photos/HomePhotoPreviewGrid'
import BlurText from '~/components/reactbits/BlurText'
import ArchiveGroupsList from '~/components/home/ArchiveGroupsList'

const { size } = POSTS_CONFIG.homePageConfig

let showPosts = []
const pinnedPosts = await getPinnedPosts()
const hasPinnedPosts = pinnedPosts.length > 0
if (hasPinnedPosts) {
  showPosts = pinnedPosts
} else {
  showPosts = await getNumPosts(size)
}

const sortedPosts = showPosts.slice().sort((a, b) => {
  const dateA = a.data.updatedDate ?? a.data.pubDate
  const dateB = b.data.updatedDate ?? b.data.pubDate
  return dateB.getTime() - dateA.getTime()
})

const archiveMap = new Map<number, typeof sortedPosts>()
for (const post of sortedPosts) {
  const date = post.data.updatedDate ?? post.data.pubDate
  const year = date.getFullYear()
  const group = archiveMap.get(year)
  if (group) {
    group.push(post)
  } else {
    archiveMap.set(year, [post])
  }
}
const archiveGroups = Array.from(archiveMap.entries()).sort((a, b) => b[0] - a[0])
const archiveGroupsForUI = archiveGroups.map(([year, posts]) => ({
  year,
  posts: posts.map((post) => {
    const date = post.data.updatedDate ?? post.data.pubDate
    return {
      date: formatDate(date, 'iso'),
      title: post.data.title,
      url: `/posts/${post.id}`,
    }
  }),
}))

const photoPreviewList = PhotosList.flatMap((album) =>
  album.photos.map((photo) => ({
    ...photo,
    date: album.date,
    albumTitle: album.title,
  }))
)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 10)
const homeSvgBackgrounds = Object.values(
  import.meta.glob<string>('/src/assets/svg/*.svg', { eager: true, import: 'default', query: '?url' })
)
const initialHomeSvgBackground = homeSvgBackgrounds[0] ?? ''
---

<Layout title="Readme" description={SITE.description}>
  <div class="relative z-[1] px-6 py-8 sm:px-8 sm:py-10 font-mono text-[15px] leading-7">
    <!-- Refined Background with Subtle Noise Overlay -->
    <div class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 overflow-hidden">
      <div
        id="home-random-svg-bg"
        class="absolute inset-0 bg-right bg-contain bg-no-repeat opacity-60"
        data-svg-list={JSON.stringify(homeSvgBackgrounds)}
        style={`background-image: url('${initialHomeSvgBackground}');`}
      ></div>
      <!-- Enhanced gradient overlays for better contrast -->
      <div class="absolute inset-0 dark:hidden bg-[linear-gradient(135deg,rgba(255,255,255,0.5)_0%,rgba(255,255,255,0.85)_50%,rgba(255,255,255,0.75)_100%)]"></div>
      <div class="absolute inset-0 hidden dark:block bg-[linear-gradient(135deg,rgba(2,6,23,0.6)_0%,rgba(2,6,23,0.9)_50%,rgba(2,6,23,0.8)_100%)]"></div>
      <!-- Subtle radial glow -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(120,119,198,0.08),transparent_60%)] dark:bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(167,139,250,0.1),transparent_60%)]"></div>
      <!-- Decorative grain texture -->
      <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
    </div>

    <!-- Main Hero Section -->
    <section class="min-h-[65svh] sm:min-h-[70svh] flex flex-col justify-center gap-8">
      <!-- Refined Name Display - Much Smaller -->
      <BlurText
        text={SITE.title}
        animateBy="letters"
        direction="top"
        delay={80}
        className="font-sans text-[clamp(2.5rem,6vw,5rem)] leading-[1.1] tracking-[-0.04em] font-semibold text-foreground uppercase"
        client:load
      />

      <!-- Enhanced subtitle area -->
      <div class="fade-up animation-delay-200 flex flex-col gap-3">
        <p class="text-base sm:text-lg font-sans font-normal tracking-tight text-foreground/90">Programmer & Writer</p>
        <div class="flex items-center gap-4 text-sm text-muted-foreground">
          <span class="inline-flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Available for work
          </span>
          <span>·</span>
          <span>Nanjing, China</span>
        </div>
      </div>

      <!-- Social Links with Enhanced Styling -->
      <div class="fade-up animation-delay-300 flex flex-wrap gap-3 pt-2">
        {
          SOCIAL_LINKS.map((item) => {
            return (
              <SocialLink href={item.url} icon={item.icon} aria-label={`Link of ${item.name}`} count={item.count} label="followers" />
            )
          })
        }
      </div>

    </section>

    <!-- Divider with decorative element -->
    <div class="flex items-center gap-4 py-8">
      <div class="flex-1 h-px bg-border/40"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-border/60"></div>
      <div class="flex-1 h-px bg-border/40"></div>
    </div>

    <!-- Archive Section -->
    <section class="py-6">
      <div class="flex items-baseline justify-between gap-4 mb-6">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-mono text-muted-foreground uppercase tracking-wider">Writing</span>
            <span class="w-6 h-px bg-border/50"></span>
          </div>
          <h2 class="text-2xl font-sans font-medium tracking-tight text-foreground">{hasPinnedPosts ? 'Pinned' : 'Recent'}</h2>
        </div>
        <a href="/posts" class="group flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
          <span>View all</span>
          <span class="group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
      </div>

      <ArchiveGroupsList groups={archiveGroupsForUI} client:visible />
    </section>

    <!-- Divider -->
    <div class="flex items-center gap-4 py-8">
      <div class="flex-1 h-px bg-border/40"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-border/60"></div>
      <div class="flex-1 h-px bg-border/40"></div>
    </div>

    <!-- Photo Preview Section -->
    <section class="py-6">
      <div class="flex items-baseline justify-between gap-4 mb-6">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-mono text-muted-foreground uppercase tracking-wider">Photography</span>
            <span class="w-6 h-px bg-border/50"></span>
          </div>
          <h2 class="text-2xl font-sans font-medium tracking-tight text-foreground">Latest Shots</h2>
        </div>
        <a href="/photos" class="group flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
          <span>View gallery</span>
          <span class="group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
      </div>
      <HomePhotoPreviewGrid photos={photoPreviewList} title="Latest Shots" description="Recent captures from everyday life." client:load />
    </section>

  </div>
</Layout>

<script is:inline>
  const homeBgEl = document.getElementById('home-random-svg-bg')
  const homeSvgListRaw = homeBgEl?.getAttribute('data-svg-list') ?? '[]'
  let homeSvgList = []
  try {
    const parsedSvgList = JSON.parse(homeSvgListRaw)
    if (Array.isArray(parsedSvgList)) {
      homeSvgList = parsedSvgList.filter((item) => typeof item === 'string')
    }
  } catch {
    homeSvgList = []
  }

  if (homeBgEl && homeSvgList.length > 0) {
    let randomIndex = Math.floor(Math.random() * homeSvgList.length)
    try {
      const cacheKey = 'home-random-svg-index'
      const previousIndex = Number(window.sessionStorage.getItem(cacheKey))
      if (Number.isInteger(previousIndex) && homeSvgList.length > 1 && previousIndex === randomIndex) {
        randomIndex = (randomIndex + 1) % homeSvgList.length
      }
      window.sessionStorage.setItem(cacheKey, String(randomIndex))
    } catch {
      // Ignore sessionStorage errors in restricted contexts.
    }
    homeBgEl.style.backgroundImage = `url("${homeSvgList[randomIndex]}")`
  }
</script>
