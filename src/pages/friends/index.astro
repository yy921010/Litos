---
import { FRIEND_LINKS, FRIENDS_CONFIG } from '~/config'
import Layout from '~/layouts/Layout.astro'
import PageTitle from '~/components/base/PageTitle.astro'
import Galaxy from '~/components/reactbits/Galaxy'

const { title, description, introduce } = FRIENDS_CONFIG
---

<Layout {title} {description}>
  <div class="relative z-[1] px-6 py-8 pb-10 sm:px-8">
    <div class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.72]">
        <Galaxy
          mouseRepulsion={false}
          density={1.2}
          glowIntensity={0.22}
          saturation={0.3}
          hueShift={210}
          twinkleIntensity={0.25}
          client:load
        />
      </div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(120,120,255,0.2),transparent_42%),linear-gradient(to_bottom,rgba(0,0,0,0),hsl(var(--background)/0.58))]"></div>
    </div>

    <PageTitle {title} {introduce} />

    <section class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        FRIEND_LINKS.map((friend) => (
          <a
            href={friend.url}
            target="_blank"
            rel="noreferrer"
            class="group rounded-xl border border-border/70 bg-muted/25 p-4 transition-all duration-300 hover:border-foreground/30 hover:bg-muted/40"
          >
            <div class="flex items-start gap-3">
              <div class="size-10 shrink-0 overflow-hidden rounded-full border border-border/60 bg-background/70">
                {friend.avatar ? <img src={friend.avatar} alt={friend.name} class="size-full object-cover" loading="lazy" decoding="async" /> : <div class="size-full" />}
              </div>
              <div class="min-w-0">
                <h2 class="truncate font-sans text-lg font-semibold text-foreground">{friend.name}</h2>
                <p class="mt-1 line-clamp-2 text-sm text-muted-foreground">{friend.description}</p>
              </div>
            </div>

            {friend.tags && friend.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {friend.tags.map((tag) => (
                  <span class="rounded-md border border-border/70 bg-background/40 px-2 py-0.5 text-xs text-muted-foreground">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))
      }
    </section>
  </div>
</Layout>
