---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { POSTS_CONFIG } from '~/config'
import { getAllPosts } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'
import Pagination from '~/components/base/Pagination.astro'
import List from '~/components/posts/card/List.astro'
import PageTitle from '~/components/base/PageTitle.astro'
import Noise from '~/components/reactbits/Noise'
import PostKindTabs from '~/components/posts/base/PostKindTabs.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const sortedPosts = await getAllPosts()

  return paginate(sortedPosts, {
    pageSize: POSTS_CONFIG.postPageConfig.size,
  })
}

interface Props {
  page: Page<CollectionEntry<'posts'>>
}

const { page } = Astro.props

const { title, description, introduce } = POSTS_CONFIG
---

<Layout {title} {description}>
  <div class="relative z-[1] py-8 pb-10 px-6 sm:px-8">
    <div class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.14]">
        <Noise patternSize={768} patternRefreshInterval={5} patternAlpha={14} client:load />
      </div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(130,140,255,0.15),transparent_40%),linear-gradient(to_bottom,rgba(0,0,0,0),hsl(var(--background)/0.42))]"></div>
    </div>

    <PageTitle {title} {introduce} />
    <PostKindTabs active="posts" />
    <div class="mt-12 fade-up">
      <List posts={page.data} type={POSTS_CONFIG.postPageConfig.type} coverLayout={POSTS_CONFIG.postPageConfig?.coverLayout} />
    </div>
    <Pagination {page} baseUrl="/posts" />
  </div>
</Layout>
